# .env.small — t3.small (2 vCPU) 평시 프로파일
# configure.sh가 이 파일의 값을 .env에 반영한다.

# ── Gunicorn GEN (port 5000) ──────────────────────────────────
GUNICORN_WORKERS=2
GUNICORN_THREADS=4

# ── bcrypt 동시 실행 제한 (per worker) ───────────────────────
# t3.small: worker당 1개 → 최대 2개 동시 bcrypt (2 workers × 1)
BCRYPT_SEMAPHORE=1

# ── VIP 포트 분리 (평시 비활성) ──────────────────────────────
# t3.small은 리소스 부족으로 Gunicorn 인스턴스를 두 개 운용하지 않는다.
VIP_ENABLED=false
